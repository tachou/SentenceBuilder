# Cloud TTS (Google Cloud Text-to-Speech API key)
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_CLOUD_TTS_API_KEY=your-google-cloud-tts-api-key-here

# LLM Grammar Validation (Anthropic API key)
# Get one at: https://console.anthropic.com/
VITE_LLM_API_KEY=your-anthropic-api-key-here
